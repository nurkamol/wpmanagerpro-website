---
const RELEASES_URL = 'https://github.com/nurkamol/wp-manager-pro/releases/latest';
const GITHUB_RELEASES = 'https://github.com/nurkamol/wp-manager-pro/releases';

const releases = [
  {
    version: 'v2.9.4',
    date: '2026-03-18',
    badge: 'Latest',
    badgeColor: 'blue',
    changes: [
      'Media Library modal deep root-cause fix — resolves iframe isolation issues',
      'Switched to IIFE build format for improved WordPress compatibility',
      'Eliminated all module-type script loading conflicts',
      'Cleaned up asset enqueuing and dependency chain',
    ],
  },
  {
    version: 'v2.9.3',
    date: '2026-03-17',
    badge: null,
    badgeColor: null,
    changes: [
      'Image Tools: fixed conversion settings persistence and toggle behavior',
      'Malware Scanner: full inspect, quarantine, delete, and ignore actions',
      'Sidebar environment badge completely redesigned — cleaner, smaller',
      'UI polish across scanner results and action dialogs',
    ],
  },
  {
    version: 'v2.9.2',
    date: '2026-03-17',
    badge: null,
    badgeColor: null,
    changes: [
      'WordPress Media Library bridge — native media picker now works inside plugin iframe',
      'Settings branding: logo picker using native WP media selector',
      'Fixed media picker button visibility and selection callback',
    ],
  },
];
---

<section id="changelog" class="py-24 sm:py-32" style="background-color: #f8fafc;">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section header -->
    <div class="text-center mb-14">
      <div
        class="inline-flex items-center gap-2 bg-violet-50 border border-violet-100 text-violet-700 text-sm font-semibold px-4 py-1.5 rounded-full mb-5"
      >
        <svg
          width="13"
          height="13"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline>
        </svg>
        Release Notes
      </div>
      <h2 class="text-4xl sm:text-5xl font-extrabold text-slate-900 tracking-tight leading-tight mb-5">
        What's new
      </h2>
      <p class="max-w-lg mx-auto text-lg text-slate-500 leading-relaxed">
        Actively developed and regularly updated. Here's what landed recently.
      </p>
    </div>

    <!-- Timeline -->
    <div class="relative">
      <!-- Vertical line -->
      <div
        class="absolute left-[19px] sm:left-[23px] top-2 bottom-0 w-px bg-gradient-to-b from-blue-200 via-slate-200 to-transparent"
      >
      </div>

      <div class="space-y-10">
        {
          releases.map((release, i) => (
            <div class="relative flex gap-5 sm:gap-7">
              <!-- Timeline dot -->
              <div class="relative flex-shrink-0">
                <div
                  class={`w-10 h-10 rounded-full border-2 flex items-center justify-center shadow-sm flex-shrink-0 ${i === 0 ? 'bg-blue-600 border-blue-600' : 'bg-white border-slate-200'}`}
                >
                  {i === 0 ? (
                    <svg
                      width="14"
                      height="14"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="white"
                      stroke-width="3"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
                    </svg>
                  ) : (
                    <div class="w-2.5 h-2.5 rounded-full bg-slate-300" />
                  )}
                </div>
              </div>

              <!-- Card -->
              <div
                class={`flex-1 rounded-2xl border p-5 sm:p-6 bg-white shadow-sm mb-1 transition-all duration-200 hover:shadow-md ${i === 0 ? 'border-blue-100 ring-1 ring-blue-100/50' : 'border-slate-200'}`}
              >
                <div class="flex items-start justify-between gap-3 mb-4 flex-wrap">
                  <div class="flex items-center gap-3 flex-wrap">
                    <span class="text-lg font-black text-slate-900 font-mono">
                      {release.version}
                    </span>
                    {release.badge && (
                      <span class="inline-flex items-center gap-1 bg-blue-100 text-blue-700 text-xs font-bold px-2.5 py-0.5 rounded-full">
                        <span class="w-1.5 h-1.5 rounded-full bg-blue-500 animate-pulse inline-block" />
                        {release.badge}
                      </span>
                    )}
                  </div>
                  <time class="text-xs text-slate-400 font-mono flex-shrink-0">
                    {release.date}
                  </time>
                </div>

                <ul class="space-y-2">
                  {release.changes.map((change) => (
                    <li class="flex items-start gap-2.5 text-sm text-slate-600">
                      <svg
                        width="13"
                        height="13"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="3"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        class={`flex-shrink-0 mt-0.5 ${i === 0 ? 'text-blue-500' : 'text-slate-400'}`}
                      >
                        <polyline points="20 6 9 17 4 12" />
                      </svg>
                      {change}
                    </li>
                  ))}
                </ul>

                {i === 0 && (
                  <div class="mt-4 pt-4 border-t border-slate-100">
                    <a
                      href={RELEASES_URL}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="inline-flex items-center gap-1.5 text-sm font-semibold text-blue-600 hover:text-blue-700 transition-colors duration-200"
                    >
                      <svg
                        width="13"
                        height="13"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      >
                        <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4" />
                        <polyline points="7 10 12 15 17 10" />
                        <line x1="12" y1="15" x2="12" y2="3" />
                      </svg>
                      Download v2.9.4
                    </a>
                  </div>
                )}
              </div>
            </div>
          ))
        }
      </div>
    </div>

    <!-- View all link -->
    <div class="mt-10 text-center">
      <a
        href={GITHUB_RELEASES}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-sm font-semibold text-slate-600 hover:text-slate-900 border border-slate-200 hover:border-slate-300 bg-white hover:bg-slate-50 px-5 py-2.5 rounded-xl transition-all duration-200 shadow-sm"
      >
        View full changelog
        <svg
          width="13"
          height="13"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
      </a>
    </div>
  </div>
</section>
