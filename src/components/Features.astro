---
const features = [
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"></path></svg>`,
    title: 'Plugin Manager',
    description: 'Install, activate, deactivate, update, and delete plugins. Search WordPress.org directly from your panel.',
    color: 'indigo',
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>`,
    title: 'Theme Manager',
    description: 'Browse, install, activate, and delete themes. Preview before switching — no FTP needed.',
    color: 'violet',
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3h18v18H3z"/><path d="M3 9h18M9 3v18"/></svg>`,
    title: 'File Manager',
    description: 'Browse and edit files directly. Syntax-aware code editor for PHP, JS, CSS, and more.',
    color: 'amber',
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/></svg>`,
    title: 'Database Manager',
    description: 'Browse tables, run SQL queries, and search & replace with full serialized data support.',
    color: 'teal',
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
    title: 'Security Scanner',
    description: 'Scan for malware, inspect suspicious files, and quarantine or delete threats in one click.',
    color: 'red',
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>`,
    title: 'Security Suite',
    description: 'Login limiter, IP blocklist, 2FA (TOTP), XML-RPC control, and file integrity monitoring.',
    color: 'orange',
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>`,
    title: 'Agency Tools',
    description: 'White-label login, coming soon mode, field groups, custom post types, and client reports.',
    color: 'pink',
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>`,
    title: 'Performance',
    description: 'DB cleanup, transient manager, object cache, Redis browser, and caching controls.',
    color: 'yellow',
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
    title: 'Cron Manager',
    description: 'Browse scheduled events, trigger manually, add custom schedules, and monitor cron health.',
    color: 'cyan',
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>`,
    title: 'User Manager',
    description: 'List users, change roles, and login-as any user with safe impersonation and audit control.',
    color: 'slate',
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>`,
    title: 'Debug Tools',
    description: 'Toggle WP_DEBUG flags, view error logs live, and get full system info at a glance.',
    color: 'blue',
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 9h6M9 12h6M9 15h4"/></svg>`,
    title: 'Image Tools',
    description: 'WebP/AVIF conversion, bulk thumbnail regeneration, JPEG quality and compression controls.',
    color: 'green',
  },
];

const iconColors: Record<string, string> = {
  indigo:  'bg-indigo-50 text-indigo-600',
  violet:  'bg-violet-50 text-violet-600',
  amber:   'bg-amber-50 text-amber-600',
  teal:    'bg-teal-50 text-teal-600',
  red:     'bg-red-50 text-red-600',
  orange:  'bg-orange-50 text-orange-600',
  pink:    'bg-pink-50 text-pink-600',
  yellow:  'bg-yellow-50 text-yellow-600',
  cyan:    'bg-cyan-50 text-cyan-600',
  slate:   'bg-slate-100 text-slate-600',
  blue:    'bg-blue-50 text-blue-600',
  green:   'bg-green-50 text-green-600',
};
---

<section id="features" class="py-24 sm:py-32 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section header -->
    <div class="max-w-2xl mb-16">
      <div class="inline-flex items-center gap-2 bg-indigo-50 border border-indigo-100 text-indigo-700 text-[13px] font-semibold px-3.5 py-1.5 rounded-full mb-5">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
        </svg>
        12 Powerful Modules
      </div>
      <h2 class="text-4xl sm:text-5xl font-black text-slate-900 tracking-tight leading-[1.1] mb-5">
        Everything your site needs.<br />
        <span class="text-slate-400 font-bold">Nothing it doesn't.</span>
      </h2>
      <p class="text-lg text-slate-500 leading-relaxed">
        WP Manager Pro bundles a complete suite of professional WordPress tools into a single, blazing-fast React interface. No more plugin sprawl.
      </p>
    </div>

    <!-- Features grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-px bg-slate-100 border border-slate-100 rounded-2xl overflow-hidden">
      {features.map((feature, i) => (
        <div class={`group bg-white p-6 hover:bg-slate-50/70 transition-colors duration-200 ${i === 0 ? 'rounded-tl-2xl' : ''} ${i === 2 ? 'rounded-tr-2xl' : ''} ${i === 9 ? 'rounded-bl-2xl' : ''} ${i === 11 ? 'rounded-br-2xl' : ''}`}>
          <div class={`w-10 h-10 rounded-xl flex items-center justify-center mb-4 ${iconColors[feature.color] || iconColors.slate}`} set:html={feature.icon}></div>
          <h3 class="text-[15px] font-bold text-slate-900 mb-1.5">{feature.title}</h3>
          <p class="text-sm text-slate-500 leading-relaxed">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
