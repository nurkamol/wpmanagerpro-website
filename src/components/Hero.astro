---
const GITHUB_URL = 'https://github.com/nurkamol/wp-manager-pro';
const RELEASES_URL = 'https://github.com/nurkamol/wp-manager-pro/releases/latest';

const stats = [
  { value: '12', label: 'Modules' },
  { value: '10+', label: 'Plugins replaced' },
  { value: 'Free', label: 'Open-source' },
];
---

<section
  class="relative overflow-hidden pt-[60px]"
  style="background: linear-gradient(135deg, #f8f7ff 0%, #ffffff 50%, #faf5ff 100%);"
>
  <!-- Subtle grid -->
  <div
    class="absolute inset-0 pointer-events-none opacity-[0.035]"
    style="background-image: linear-gradient(#6366f1 1px, transparent 1px), linear-gradient(90deg, #6366f1 1px, transparent 1px); background-size: 48px 48px;"
  ></div>

  <!-- Glow blobs -->
  <div
    class="absolute -top-24 -right-24 w-[600px] h-[600px] rounded-full pointer-events-none opacity-[0.07] blur-3xl"
    style="background: radial-gradient(circle, #818cf8 0%, transparent 70%);"
  ></div>
  <div
    class="absolute bottom-0 -left-32 w-[400px] h-[400px] rounded-full pointer-events-none opacity-[0.05] blur-3xl"
    style="background: radial-gradient(circle, #a78bfa 0%, transparent 70%);"
  ></div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-16 py-20 lg:py-28">

      <!-- Left: Text content -->
      <div class="flex-1 max-w-xl lg:max-w-none">
        <!-- Badge -->
        <div class="inline-flex items-center gap-2 mb-7">
          <span
            class="inline-flex items-center gap-1.5 bg-indigo-50 border border-indigo-200/80 text-indigo-700 text-[13px] font-semibold px-3.5 py-1.5 rounded-full"
          >
            <span class="w-1.5 h-1.5 rounded-full bg-indigo-500 animate-pulse"></span>
            v3.1.0 — Now Available
          </span>
        </div>

        <!-- Headline -->
        <h1 class="text-[3.25rem] sm:text-[4rem] lg:text-[4.5rem] font-black text-slate-900 leading-[1.05] tracking-tight mb-6">
          The WordPress<br />
          admin you<br />
          <span
            class="text-transparent bg-clip-text"
            style="background-image: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);"
          >actually want.</span>
        </h1>

        <!-- Subtext -->
        <p class="text-lg sm:text-xl text-slate-500 leading-relaxed mb-8 max-w-lg">
          Replace a dozen separate admin plugins with one fast, React-powered control panel.
          Everything in one place — nothing you don't need.
        </p>

        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row gap-3 mb-10">
          <a
            href={RELEASES_URL}
            target="_blank"
            rel="noopener noreferrer"
            class="group inline-flex items-center justify-center gap-2.5 bg-indigo-600 hover:bg-indigo-500 text-white font-bold text-[15px] px-7 py-3.5 rounded-xl transition-all duration-200 shadow-lg shadow-indigo-600/25 hover:shadow-indigo-500/35 hover:-translate-y-0.5"
          >
            Download Free
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-y-0.5 transition-transform duration-200">
              <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"></path>
              <polyline points="7 10 12 15 17 10"></polyline>
              <line x1="12" y1="15" x2="12" y2="3"></line>
            </svg>
          </a>
          <a
            href={GITHUB_URL}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2.5 bg-white hover:bg-slate-50 border border-slate-200 hover:border-slate-300 text-slate-700 font-semibold text-[15px] px-7 py-3.5 rounded-xl transition-all duration-200 hover:-translate-y-0.5"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"></path>
            </svg>
            View on GitHub
          </a>
        </div>

        <!-- Meta tags -->
        <div class="flex items-center gap-5 flex-wrap text-sm text-slate-400 font-medium">
          <span class="flex items-center gap-1.5">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
            Free & open-source
          </span>
          <span class="text-slate-200">|</span>
          <span>WordPress 5.9+</span>
          <span class="text-slate-200">|</span>
          <span>PHP 7.4+</span>
          <span class="text-slate-200">|</span>
          <span>GPL-2.0</span>
        </div>
      </div>

      <!-- Right: Plugin UI mockup -->
      <div class="flex-1 w-full max-w-[600px] lg:max-w-none">
        <div
          class="relative rounded-2xl overflow-hidden shadow-2xl shadow-slate-900/15 border border-slate-200/80 ring-1 ring-slate-900/5"
          style="background: #f8fafc;"
        >
          <!-- Window chrome -->
          <div class="flex items-center gap-2 px-4 py-3 border-b border-slate-200/80 bg-white">
            <span class="w-3 h-3 rounded-full bg-red-400/80"></span>
            <span class="w-3 h-3 rounded-full bg-amber-400/80"></span>
            <span class="w-3 h-3 rounded-full bg-green-400/80"></span>
            <span class="ml-3 text-xs text-slate-400 font-medium">WP Manager Pro</span>
          </div>

          <!-- Sidebar + content layout -->
          <div class="flex" style="min-height: 340px;">
            <!-- Sidebar -->
            <div class="w-48 border-r border-slate-200/80 bg-white flex-shrink-0 py-3">
              <div class="px-3 mb-2">
                <span class="text-[10px] text-slate-400 font-semibold uppercase tracking-widest px-2">Overview</span>
              </div>
              {[
                { label: 'Dashboard', active: true, icon: '▦' },
                { label: 'Plugins', active: false, icon: '◈' },
                { label: 'Themes', active: false, icon: '◉' },
                { label: 'Database', active: false, icon: '◫' },
                { label: 'Security', active: false, icon: '◬' },
                { label: 'Performance', active: false, icon: '◎' },
                { label: 'Users', active: false, icon: '◍' },
              ].map(item => (
                <div
                  class={`flex items-center gap-2.5 mx-2 px-2.5 py-1.5 rounded-lg mb-0.5 text-xs font-medium cursor-default ${item.active ? 'bg-indigo-600 text-white' : 'text-slate-500'}`}
                >
                  <span class="opacity-70">{item.icon}</span>
                  {item.label}
                </div>
              ))}
            </div>

            <!-- Main content -->
            <div class="flex-1 p-4">
              <!-- Stat cards -->
              <div class="grid grid-cols-2 sm:grid-cols-4 gap-2.5 mb-3">
                {[
                  { label: 'Plugins', count: '24', color: '#6366f1' },
                  { label: 'Themes', count: '8', color: '#8b5cf6' },
                  { label: 'Users', count: '12', color: '#10b981' },
                  { label: 'DB Tables', count: '47', color: '#f59e0b' },
                ].map(item => (
                  <div class="rounded-xl p-3 bg-white border border-slate-200/80 shadow-sm">
                    <div class="text-2xl font-black text-slate-900 font-mono leading-none mb-1">{item.count}</div>
                    <div class="text-[11px] text-slate-400 font-medium">{item.label}</div>
                    <div class="mt-2 h-0.5 rounded-full w-8" style={`background: ${item.color};`}></div>
                  </div>
                ))}
              </div>

              <!-- Status rows -->
              <div class="space-y-2">
                {[
                  { label: 'Plugin Manager', status: 'Active', dot: '#22c55e' },
                  { label: 'Security Scanner', status: 'Clean', dot: '#22c55e' },
                  { label: 'DB Cleanup', status: '12 MB freed', dot: '#6366f1' },
                  { label: 'Maintenance Mode', status: 'Off', dot: '#94a3b8' },
                ].map(item => (
                  <div class="flex items-center justify-between bg-white rounded-xl px-3.5 py-2.5 border border-slate-200/80 shadow-sm">
                    <span class="text-xs text-slate-600 font-medium">{item.label}</span>
                    <span class="flex items-center gap-1.5 text-xs font-semibold text-slate-500">
                      <span class="w-1.5 h-1.5 rounded-full flex-shrink-0" style={`background: ${item.dot};`}></span>
                      {item.status}
                    </span>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>

        <!-- Floating badges below mockup -->
        <div class="flex items-center justify-center gap-3 mt-5 flex-wrap">
          {[
            { label: '12 modules', bg: 'bg-indigo-50', text: 'text-indigo-700', border: 'border-indigo-100' },
            { label: 'React-powered', bg: 'bg-sky-50', text: 'text-sky-700', border: 'border-sky-100' },
            { label: 'REST API', bg: 'bg-violet-50', text: 'text-violet-700', border: 'border-violet-100' },
            { label: 'Dark mode', bg: 'bg-slate-50', text: 'text-slate-600', border: 'border-slate-200' },
          ].map(badge => (
            <span class={`inline-flex items-center text-[12px] font-semibold px-3 py-1 rounded-full border ${badge.bg} ${badge.text} ${badge.border}`}>
              {badge.label}
            </span>
          ))}
        </div>
      </div>

    </div>
  </div>
</section>
