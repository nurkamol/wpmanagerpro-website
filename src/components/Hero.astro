---
const GITHUB_URL = 'https://github.com/nurkamol/wp-manager-pro';
const RELEASES_URL = 'https://github.com/nurkamol/wp-manager-pro/releases/latest';
---

<section
  class="relative min-h-screen flex items-center justify-center overflow-hidden"
  style="background-color: #0f172a;"
>
  <!-- Background grid pattern -->
  <div
    class="absolute inset-0 opacity-40"
    style="background-image: radial-gradient(circle at 1px 1px, rgba(59,130,246,0.15) 1px, transparent 0); background-size: 40px 40px;"
  >
  </div>

  <!-- Background glow -->
  <div
    class="absolute top-1/4 left-1/2 -translate-x-1/2 w-[800px] h-[500px] rounded-full opacity-10 blur-3xl pointer-events-none"
    style="background: radial-gradient(ellipse, #3b82f6 0%, transparent 70%);"
  >
  </div>

  <!-- Decorative orbs -->
  <div
    class="absolute top-20 right-10 w-72 h-72 rounded-full opacity-5 blur-2xl pointer-events-none"
    style="background: #60a5fa;"
  >
  </div>
  <div
    class="absolute bottom-20 left-10 w-64 h-64 rounded-full opacity-5 blur-2xl pointer-events-none"
    style="background: #818cf8;"
  >
  </div>

  <div class="relative z-10 max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center pt-24 pb-20">
    <!-- Version badge -->
    <div class="inline-flex items-center gap-2 mb-8">
      <span
        class="inline-flex items-center gap-2 bg-blue-600/15 border border-blue-500/30 text-blue-300 text-sm font-medium px-4 py-1.5 rounded-full backdrop-blur-sm"
      >
        <span class="text-base leading-none">✨</span>
        v2.9.4 — Now Available
        <span
          class="inline-flex w-1.5 h-1.5 rounded-full bg-blue-400 animate-pulse ml-0.5"
        ></span>
      </span>
    </div>

    <!-- Main headline -->
    <h1 class="text-5xl sm:text-6xl lg:text-7xl font-extrabold text-white leading-[1.08] tracking-tight mb-6">
      One plugin to<br />
      <span
        class="text-transparent bg-clip-text"
        style="background-image: linear-gradient(135deg, #60a5fa 0%, #3b82f6 40%, #818cf8 100%);"
      >
        manage everything.
      </span>
    </h1>
    <p class="text-xl sm:text-2xl font-medium text-slate-400 mb-6 tracking-tight">
      Your complete WordPress control panel.
    </p>

    <!-- Subheadline -->
    <p class="max-w-2xl mx-auto text-base sm:text-lg text-slate-400 leading-relaxed mb-10">
      Replace 10+ separate admin plugins with a single, fast, React-powered interface.
      Plugin manager, database tools, file manager, security scanner, and more —
      all in one place.
    </p>

    <!-- CTA Buttons -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-8">
      <a
        href={RELEASES_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="group inline-flex items-center gap-2.5 bg-blue-600 hover:bg-blue-500 text-white font-semibold text-base px-7 py-3.5 rounded-xl transition-all duration-200 shadow-2xl shadow-blue-600/30 hover:shadow-blue-500/40 hover:-translate-y-0.5"
      >
        <svg
          width="17"
          height="17"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="group-hover:translate-y-0.5 transition-transform duration-200"
        >
          <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"></path>
          <polyline points="7 10 12 15 17 10"></polyline>
          <line x1="12" y1="15" x2="12" y2="3"></line>
        </svg>
        Download Free
      </a>

      <a
        href={GITHUB_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2.5 bg-white/5 hover:bg-white/10 border border-white/15 hover:border-white/25 text-white font-semibold text-base px-7 py-3.5 rounded-xl transition-all duration-200 backdrop-blur-sm hover:-translate-y-0.5"
      >
        <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor">
          <path
            d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"
          ></path>
        </svg>
        View on GitHub
      </a>
    </div>

    <!-- Meta info -->
    <p class="text-sm text-slate-500 flex items-center justify-center gap-3 flex-wrap">
      <span class="flex items-center gap-1.5">
        <svg
          width="13"
          height="13"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="text-green-500"
        >
          <polyline points="20 6 9 17 4 12"></polyline>
        </svg>
        Free &amp; open-source
      </span>
      <span class="text-slate-700">·</span>
      <span>WordPress 5.9+</span>
      <span class="text-slate-700">·</span>
      <span>PHP 7.4+</span>
      <span class="text-slate-700">·</span>
      <span>GPL-2.0</span>
    </p>

    <!-- Hero visual — animated terminal-like card -->
    <div class="mt-16 max-w-3xl mx-auto">
      <div
        class="rounded-2xl border border-slate-700/60 overflow-hidden shadow-2xl"
        style="background: #1e293b;"
      >
        <!-- Window chrome -->
        <div
          class="flex items-center gap-2 px-4 py-3 border-b border-slate-700/60"
          style="background: #0f172a;"
        >
          <span class="w-3 h-3 rounded-full bg-red-500/70"></span>
          <span class="w-3 h-3 rounded-full bg-yellow-500/70"></span>
          <span class="w-3 h-3 rounded-full bg-green-500/70"></span>
          <span class="ml-3 text-xs text-slate-500 font-mono">WP Manager Pro — WordPress Admin</span>
        </div>
        <!-- Fake UI content -->
        <div class="p-5 grid grid-cols-2 sm:grid-cols-4 gap-3">
          {
            [
              { label: 'Plugins', count: '24', icon: '🔌', color: 'blue' },
              { label: 'Themes', count: '8', icon: '🎨', color: 'purple' },
              { label: 'Users', count: '12', icon: '👥', color: 'green' },
              { label: 'DB Tables', count: '47', icon: '🗄️', color: 'orange' },
            ].map((item) => (
              <div class="rounded-xl p-3.5 border border-slate-600/40" style="background: #0f172a;">
                <div class="text-xl mb-2">{item.icon}</div>
                <div class="text-2xl font-bold text-white font-mono">{item.count}</div>
                <div class="text-xs text-slate-400 mt-0.5">{item.label}</div>
              </div>
            ))
          }
        </div>
        <div class="px-5 pb-5 grid grid-cols-1 sm:grid-cols-3 gap-3">
          {
            [
              { label: 'Plugin Manager', status: 'Active', statusColor: 'green' },
              { label: 'Security Scanner', status: 'Clean', statusColor: 'green' },
              { label: 'DB Cleanup', status: '12 MB freed', statusColor: 'blue' },
            ].map((item) => (
              <div
                class="rounded-xl px-4 py-3 border border-slate-600/40 flex items-center justify-between"
                style="background: #0f172a;"
              >
                <span class="text-xs text-slate-400">{item.label}</span>
                <span
                  class={`text-xs font-semibold ${item.statusColor === 'green' ? 'text-green-400' : 'text-blue-400'}`}
                >
                  {item.status}
                </span>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>
