---
const GITHUB_URL = 'https://github.com/nurkamol/wp-manager-pro';
const RELEASES_URL = 'https://github.com/nurkamol/wp-manager-pro/releases/latest';
const CHANGELOG_URL = 'https://github.com/nurkamol/wp-manager-pro/releases';
---

<footer class="border-t border-slate-200 bg-slate-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-8">
      <!-- Brand -->
      <div class="md:col-span-1">
        <div class="flex items-center gap-2.5 mb-4">
          <div class="w-7 h-7 rounded-lg bg-indigo-600 flex items-center justify-center flex-shrink-0">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
            </svg>
          </div>
          <span class="text-slate-900 font-bold text-[15px] tracking-tight">WP Manager Pro</span>
        </div>
        <p class="text-slate-500 text-sm leading-relaxed mb-5">
          Free & open-source WordPress management suite. Replace a dozen admin plugins with one fast, React-powered control panel.
        </p>
        <div class="flex items-center gap-3">
          <a
            href={GITHUB_URL}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 text-sm font-medium text-slate-500 hover:text-slate-900 transition-colors duration-200"
          >
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"></path>
            </svg>
            GitHub
          </a>
        </div>
      </div>

      <!-- Links -->
      <div class="flex gap-12 md:col-span-2 md:justify-end">
        <div>
          <h4 class="text-slate-400 text-[11px] font-semibold uppercase tracking-widest mb-4">Project</h4>
          <ul class="space-y-3">
            {[
              { label: 'GitHub Repository', href: GITHUB_URL, external: true },
              { label: 'Releases', href: RELEASES_URL, external: true },
              { label: 'Changelog', href: CHANGELOG_URL, external: true },
            ].map(link => (
              <li>
                <a
                  href={link.href}
                  target={link.external ? '_blank' : undefined}
                  rel={link.external ? 'noopener noreferrer' : undefined}
                  class="text-slate-500 hover:text-slate-900 text-sm transition-colors duration-200"
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <div>
          <h4 class="text-slate-400 text-[11px] font-semibold uppercase tracking-widest mb-4">Quick Links</h4>
          <ul class="space-y-3">
            {[
              { label: 'Features', href: '#features' },
              { label: 'How It Works', href: '#how-it-works' },
              { label: 'Changelog', href: '#changelog' },
            ].map(link => (
              <li>
                <a href={link.href} class="text-slate-500 hover:text-slate-900 text-sm transition-colors duration-200">
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-slate-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-5 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="text-xs text-slate-400">Built with React + WordPress REST API · GPL-2.0 License</p>
      <p class="text-xs text-slate-400">&copy; {new Date().getFullYear()} WP Manager Pro</p>
    </div>
  </div>
</footer>
