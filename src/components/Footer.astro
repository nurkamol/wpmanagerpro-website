---
const GITHUB_URL = 'https://github.com/nurkamol/wp-manager-pro';
const RELEASES_URL = 'https://github.com/nurkamol/wp-manager-pro/releases/latest';
const CHANGELOG_URL = 'https://github.com/nurkamol/wp-manager-pro/releases';
---

<footer class="bg-slate-900 border-t border-slate-800">
  <!-- Main footer content -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-8">
      <!-- Left: Brand -->
      <div class="max-w-sm">
        <div class="flex items-center gap-2.5 mb-4">
          <div
            class="w-8 h-8 rounded-lg bg-blue-600 flex items-center justify-center flex-shrink-0"
          >
            <svg
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="white"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
            </svg>
          </div>
          <span class="text-white font-semibold text-[15px] tracking-tight">WP Manager Pro</span>
        </div>
        <p class="text-slate-400 text-sm leading-relaxed mb-6">
          Free &amp; open-source WordPress management suite. Replace a dozen admin plugins with one
          powerful, React-powered control panel.
        </p>

        <!-- Stats row -->
        <div class="flex items-center gap-5 flex-wrap">
          {
            [
              { label: 'GPL-2.0', color: 'text-green-400' },
              { label: 'WordPress 5.9+', color: 'text-slate-400' },
              { label: 'PHP 7.4+', color: 'text-slate-400' },
            ].map((item) => (
              <span class={`text-xs font-medium ${item.color}`}>{item.label}</span>
            ))
          }
        </div>
      </div>

      <!-- Right: Links -->
      <div class="flex flex-col sm:flex-row gap-8 md:justify-end">
        <div>
          <h4 class="text-slate-300 text-xs font-semibold uppercase tracking-widest mb-4">
            Project
          </h4>
          <ul class="space-y-3">
            {
              [
                { label: 'GitHub Repository', href: GITHUB_URL },
                { label: 'Releases', href: RELEASES_URL },
                { label: 'Changelog', href: CHANGELOG_URL },
              ].map((link) => (
                <li>
                  <a
                    href={link.href}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-slate-400 hover:text-white text-sm transition-colors duration-200 flex items-center gap-1.5 group"
                  >
                    {link.label}
                    <svg
                      width="10"
                      height="10"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2.5"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      class="opacity-0 group-hover:opacity-100 transition-opacity duration-200"
                    >
                      <line x1="7" y1="17" x2="17" y2="7" />
                      <polyline points="7 7 17 7 17 17" />
                    </svg>
                  </a>
                </li>
              ))
            }
          </ul>
        </div>

        <div>
          <h4 class="text-slate-300 text-xs font-semibold uppercase tracking-widest mb-4">
            Quick Links
          </h4>
          <ul class="space-y-3">
            {
              [
                { label: 'Features', href: '#features' },
                { label: 'How It Works', href: '#how-it-works' },
                { label: 'Changelog', href: '#changelog' },
              ].map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="text-slate-400 hover:text-white text-sm transition-colors duration-200"
                  >
                    {link.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-slate-800">
    <div
      class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-5 flex flex-col sm:flex-row items-center justify-between gap-3"
    >
      <p class="text-xs text-slate-500 text-center sm:text-left">
        Built with React + WordPress REST API &nbsp;·&nbsp; GPL-2.0 License
      </p>
      <p class="text-xs text-slate-600 text-center sm:text-right">
        &copy; {new Date().getFullYear()} WP Manager Pro. All rights reserved.
      </p>
    </div>
  </div>
</footer>
